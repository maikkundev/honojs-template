{
  "tasks": {
    "dev": "deno run -A --watch src/index.ts",
    "push": "deno run -A npm:prisma@latest db push",
    "studio": "npx prisma studio",
    "prisma": "deno run -A --unstable npm:prisma",
    "prisma:generate": "deno task prisma generate --no-engine --schema ./prisma/schema.prisma && deno task prisma:patch",
    "prisma:patch": "deno run -A prisma/patch.ts",
    "prepare": "deno_hooks",
    "test": "deno test",
    "hook": "deno run --allow-read --allow-run --allow-write https://deno.land/x/deno_hooks@0.1.1/mod.ts"
  },
  "imports": {
    "@hono/zod-validator": "npm:@hono/zod-validator",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@^1.0.6",
    "hono": "npm:hono",
    "zod": "npm:zod"
  },
  "compilerOptions": {
    "strict": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "lint": {
    "rules": {
      "include": ["recommended"]
    },
    "files": {
      "include": ["**/*.{js,mjs,cjs,ts,tsx}"]
    }
  },
  "fmt": {
    "printWidth": 100,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "endOfLine": "lf"
  },
  "nodeModulesDir": "auto"
}
