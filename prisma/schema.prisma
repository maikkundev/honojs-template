generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["deno"]
  output          = "generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id      Int    @id @default(autoincrement())
  title   String @db.VarChar(255)
  details String @db.VarChar(2000)
}
